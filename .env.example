# External PostgreSQL database from Supabase, Neon, or another hosted provider.
# Use the pooled connection string if your provider offers one for serverless apps.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Public desktop build setting. This is safe to expose because it only points at the deployed API host.
VITE_LICENSE_API_URL="https://YOUR-NETLIFY-SITE.netlify.app"

# Optional comma-separated browser origins for public desktop API CORS.
# Use * for a desktop-only public API, or add your exact admin/custom domains.
API_CORS_ORIGIN="*"

# Server-only admin secrets. Set these in Netlify, never in frontend code.
ADMIN_TOKEN="generate-a-long-random-admin-token"
ADMIN_DASHBOARD_USER="admin"
ADMIN_DASHBOARD_PASSWORD="generate-a-long-random-dashboard-password"
ADMIN_SESSION_SECRET="generate-at-least-32-random-bytes"
