{
  "name": "forty-seven-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:backend": "tsx server/src/index.ts",
    "backend:build": "tsc -p server/tsconfig.json",
    "backend:start": "node server/dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "build": "tsc && vite build",
    "netlify:build": "prisma generate && prisma migrate deploy && npm --prefix admin-web run build",
    "admin:dev": "npm --prefix admin-web run dev",
    "admin:build": "npm --prefix admin-web run build",
    "preview": "vite preview --host 127.0.0.1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@tauri-apps/api": "^2.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "lucide-react": "^0.468.0",
    "multer": "^2.1.1",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.60.0",
    "prisma": "^6.19.3",
    "tsx": "^4.22.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
